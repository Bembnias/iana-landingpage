---
/**
 * FAQSection
 * Sekcja Frequently Asked Questions z dynamicznie pobieranymi danymi z Sanity.io.
 */
import { loadQuery } from "../sanity/lib/load-query";

const { data: faqItems } = await loadQuery<any[]>({
  query: `*[_type == "faq"] | order(order asc) {
    question,
    answer
  }`,
});

// Fallback w przypadku braku danych w Sanity, by nie było na produkcji pustej dziury - design będzie widoczny od razu.
const defaultFaq = [
  {
    question: "Dla kogo przeznaczone są produkty iana?",
    answer:
      "Są przeznaczone dla każdego poszukującego dobrze zbadanego wellbeingu.",
  },
  {
    question: "Czy suplementacja po 40. jest konieczna?",
    answer:
      "Zmiany w ciele domagają się dodatkowej, przemyślanej suplementacji.",
  },
  {
    question: "Czy produkty na skórę iana mogę stosować codziennie?",
    answer: "Tak, produkty iana nadają się do codziennego użytku.",
  },
  {
    question:
      "Skąd pochodzą składniki do naszych produktów i czy są bezpieczne?",
    answer:
      "Wszystkie składniki są w ponad 98% pochodzenia naturalnego z certyfikatów.",
  },
  {
    question:
      "Czy stosowanie produktów iana rzeczywiście wspiera komfort życia?",
    answer:
      "Tak, potwierdzają to nasze badania kliniczne oraz wysokie zadowolenie klientów.",
  },
  {
    question:
      "Na czym polega program testowy iana i kto może do niego dołączyć?",
    answer:
      "W programie może wziąć udział każdy, kto chce opowiedzieć o swoich wrażeniach w mediach społecznościowych.",
  },
];

const itemsToRender = faqItems && faqItems.length > 0 ? faqItems : defaultFaq;

const formatText = (text: string) => {
  if (!text) return "";

  return text.replace(/\b(iana)\b/gi, "<strong>$1</strong>");
};
---

<section class="faq" id="faq-section">
  <div class="faq__container">
    <div class="faq__pill">FAQ</div>
    <h2 class="faq__heading">NAJCZĘŚCIEJ ZADAWANE PYTANIA</h2>

    <div class="faq__accordion">
      {
        itemsToRender.map((item) => (
          <details class="faq__item" name="faq-accordion">
            <summary class="faq__question">
              <span set:html={formatText(item.question)} />
              <span class="faq__icon" />
            </summary>
            <div class="faq__answer">
              <p set:html={formatText(item.answer)} />
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .faq {
    background-color: var(--color-background-green, #f0f7f4);
    padding: 80px 24px;
    color: var(--color-dark-green);
  }

  .faq__container {
    width: 100%;
    max-width: var(--max-width, 1545px);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .faq__pill {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    background-color: var(--color-dark-green);
    color: var(--color-white);
    padding: 6px 32px;
    border-radius: 50px;
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 24px;
    text-transform: uppercase;
  }

  .faq__heading {
    font-size: var(--text-large, 2rem);
    font-weight: 400;
    text-align: center;
    color: var(--color-dark-green);
    margin-bottom: 48px;
    text-transform: uppercase;
  }

  .faq__accordion {
    width: 100%;
    display: flex;
    flex-direction: column;
  }

  .faq__item {
    border-top: 1px solid var(--color-dark-green);
  }

  /* Kreska na samym dole ostatniego elementu iana-landingpage / design */
  .faq__item:last-child {
    border-bottom: 1px solid var(--color-dark-green);
  }

  .faq__question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    width: 100%;
    padding: 24px 0;
    font-size: 1.25rem;
    color: var(--color-dark-green);
    cursor: pointer;
    list-style: none; /* Ukryj natywny trójkąt */
    transition: opacity 0.2s ease;
  }

  /* Usunięcie znacznika natywnego w Safari */
  .faq__question::-webkit-details-marker {
    display: none;
  }

  .faq__question:hover {
    opacity: 0.8;
  }

  .faq__icon {
    position: relative;
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }

  /* Linia pozioma plusa */
  .faq__icon::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 10%;
    width: 80%;
    height: 2px;
    background-color: var(--color-dark-green);
    transform: translateY(-50%);
  }

  /* Linia pionowa plusa - obrócona gdy zamknięte */
  .faq__icon::after {
    content: "";
    position: absolute;
    top: 10%;
    left: 50%;
    width: 2px;
    height: 80%;
    background-color: var(--color-dark-green);
    transform: translateX(-50%);
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
  }

  /* Jeśli <details> zawiera atrybut open (kliknięte), to schowaj pionową linię żeby powstał minus */
  .faq__item[open] .faq__icon::after {
    transform: translateX(-50%) rotate(90deg);
    opacity: 0;
  }

  .faq__answer {
    padding-bottom: 24px;
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--color-dark-green);
    animation: fadeIn 0.4s ease;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media screen and (max-width: 768px) {
    .faq__heading {
      font-size: 1.5rem;
    }

    .faq__question {
      font-size: 1rem;
      padding: 16px 0;
    }

    .faq__answer {
      font-size: 0.9375rem;
    }
  }
</style>
