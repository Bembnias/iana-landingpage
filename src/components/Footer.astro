---
/**
 * Footer
 * Stopka strony na całą szerokość ekranu
 */
import { Image } from "astro:assets";
import footerBg from "../assets/footer-background.png";
import logo from "../assets/logo.svg";
import fbIconAlt from "../assets/facebook-icon-alt.svg";
import igIconAlt from "../assets/instagram-icon-alt.svg";
import ytIconAlt from "../assets/youtube-icon-alt.svg";
import webIconAlt from "../assets/website-icon-alt.svg";

const links = [
  { label: "Produkty", href: "/produkty" },
  { label: "Kontakt", href: "/kontakt" },
  { label: "Polityka prywatności", href: "/polityka-prywatnosci" },
  { label: "Testowanie", href: "/testowanie" },
];

const socialLinks = [
  { icon: fbIconAlt, alt: "Facebook", href: "https://www.facebook.com" },
  { icon: igIconAlt, alt: "Instagram", href: "https://www.instagram.com" },
  {
    icon: ytIconAlt,
    alt: "YouTube",
    href: "https://www.youtube.com/@IanaPolska",
  },
  { icon: webIconAlt, alt: "Website", href: "https://www.iana-bynature.pl" },
];
---

<footer class="footer" id="stopka">
  <Image src={footerBg} alt="" role="presentation" class="footer__bg" />

  <div class="footer__container">
    <div class="footer__grid">
      <!-- Kolumna 1 -->
      <div class="footer__column">
        <div class="footer__col-head">
          <Image src={logo} alt="iana logo" class="footer__logo" />
        </div>
        <hr class="footer__divider" />
        <p class="footer__text">
          Produkty opracowane przez francuskie laboratorium Laboratoires
          Expanscience - ekspertów w dziedzinie ekstrakcji i artykulacji roślin.
        </p>
      </div>

      <!-- Kolumna 2 -->
      <div class="footer__column">
        <div class="footer__col-head">
          <h3 class="footer__heading">Informacje</h3>
        </div>
        <hr class="footer__divider" />
        <ul class="footer__links">
          {
            links.map((link) => (
              <li>
                <a href={link.href} class="footer__link">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Kolumna 3 -->
      <div class="footer__column">
        <div class="footer__col-head">
          <h3 class="footer__heading">O nas</h3>
        </div>
        <hr class="footer__divider" />
        <div class="footer__socials">
          {
            socialLinks.map((link) => (
              <a
                href={link.href}
                target="_blank"
                class="footer__social-link"
                aria-label={link.alt}
              >
                <Image
                  src={link.icon}
                  alt={link.alt}
                  class="footer__social-icon"
                />
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    width: 100%;
    color: var(--color-white);
    padding: 64px 24px;
    overflow: hidden;
  }

  .footer__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .footer__container {
    position: relative;
    z-index: 1;
    max-width: var(--max-width, 1545px);
    margin: 0 auto;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 80px;
  }

  .footer__column {
    display: flex;
    flex-direction: column;
    text-align: left;
  }

  .footer__col-head {
    height: 48px;
    display: flex;
    align-items: center;
  }

  .footer__logo {
    height: 38px;
    width: auto;
  }

  .footer__heading {
    font-size: 1.75rem;
    font-weight: 700;
  }

  .footer__divider {
    border: none;
    height: 1px;
    background-color: var(--color-white);
    opacity: 0.5;
    margin: 16px 0 24px 0;
  }

  .footer__text {
    font-size: 1.25rem;
    line-height: 1.5;
  }

  .footer__links {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer__link {
    font-size: 1.25rem;
    color: var(--color-white);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .footer__link:hover {
    opacity: 0.8;
  }

  .footer__socials {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .footer__social-link {
    display: flex;
    transition: transform 0.2s ease;
  }

  .footer__social-link:hover {
    transform: scale(1.05);
  }

  .footer__social-icon {
    width: 44px;
    height: 44px;
  }

  /* --- Mobile --- */
  @media screen and (max-width: 900px) {
    .footer__grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }
</style>
