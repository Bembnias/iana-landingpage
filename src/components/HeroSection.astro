---
import { Image } from "astro:assets";
import heroBackground from "../assets/hero-background.png";

/**
 * HeroSection — główna sekcja hero na landing page.
 * Pełnoekranowe tło z hero-background.png, tekst marketingowy po lewej.
 * BEM: .hero, .hero__content, .hero__heading, .hero__highlight
 */
---

<section class="hero" id="hero-section">
  <Image
    class="hero__background"
    src={heroBackground}
    alt="iana hero section banner"
    role="presentation"
    fetchpriority="high"
    loading="eager"
  />

  <div class="hero__content">
    <h1 class="hero__heading">
      Nie chcemy starzeć się<br />
      według czyichś zasad.<br />
      Dojrzałość piszemy <strong class="hero__highlight">po swojemu</strong>.
    </h1>
    <h2 class="hero__subheading">I FEEL GOOD IN MY AGE</h2>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: 70vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero__background {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -1;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    max-width: var(--max-width);
    width: 100%;
    margin: 0 auto;
    padding: 0;
    padding-top: calc(var(--navbar-height) + 48px);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }

  .hero__heading {
    color: var(--color-white);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 400;
    line-height: 1.4;
    max-width: 800px;
  }

  .hero__highlight {
    font-weight: 700;
    background-color: var(--color-light-green);
    padding: 2px 10px;
    border-radius: 30px;
  }

  .hero__subheading {
    color: var(--color-white);
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    font-weight: 700;
    letter-spacing: 0.05em;
    white-space: nowrap;
    text-align: right;
  }

  /* --- Mobile --- */
  @media screen and (max-width: 1545px) {
    .hero__content {
      padding-left: 24px;
      padding-right: 24px;
    }
  }

  @media screen and (max-width: 768px) {
    .hero__content {
      flex-direction: column;
      align-items: center;
      padding-top: calc(var(--navbar-height) + 48px + 24px);
    }

    .hero__heading {
      text-align: center;
      font-size: clamp(1.5rem, 6vw, 2.25rem);
    }

    .hero__subheading {
      text-align: center;
      font-size: clamp(1.75rem, 8vw, 2.5rem);
      white-space: normal;
    }
  }
</style>
