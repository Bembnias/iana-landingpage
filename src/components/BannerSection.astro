---
/**
 * BannerSection
 * Baner z obrazkiem tła, zaokrąglonymi rogami, tekstem i logo.
 */
import { Image } from "astro:assets";
import bannerBg from "../assets/banner-background.png";
import logo from "../assets/logo.svg";
---

<section class="banner" id="banner-section">
  <div class="banner__container">
    <div class="banner__inner">
      <Image src={bannerBg} alt="" role="presentation" class="banner__bg" />
      <div class="banner__content">
        <h2 class="banner__heading">Nowy etap. Nowe spojrzenie.</h2>
        <Image src={logo} alt="iana logo" class="banner__logo" />
      </div>
    </div>
  </div>
</section>

<style>
  .banner {
    background-color: var(--color-white);
    padding: 64px 24px 64px;
  }

  .banner__container {
    max-width: var(--max-width, 1545px);
    margin: 0 auto;
  }

  .banner__inner {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 400px;
  }

  .banner__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .banner__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 40px 24px;
  }

  .banner__heading {
    color: var(--color-white);
    font-size: var(--text-extra-large, 2.5rem);
    font-weight: 700;
    margin-bottom: 24px;
    letter-spacing: 0.02em;
  }

  .banner__logo {
    height: 64px;
    width: auto;
  }

  /* --- Mobile --- */
  @media screen and (max-width: 768px) {
    .banner__inner {
      min-height: 300px;
    }

    .banner__heading {
      font-size: var(--text-medium, 1.75rem);
    }

    .banner__logo {
      height: 48px;
    }
  }
</style>
