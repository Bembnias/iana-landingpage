---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Image from 'astro/components/Image.astro';
import { loadQuery } from '../../sanity/lib/load-query';

const { data: posts } = await loadQuery<any[]>({
  query: `*[_type == "post"] | order(publishedAt desc) {
    title,
    slug,
    teaser,
    "thumbnailUrl": thumbnail.asset->url,
    "thumbnailAlt": thumbnail.alt
  }`,
});
---

<Layout
  title="Blog — IANA"
  description="Blog IANA — artykuły o zdrowiu, wellbeingu i świadomym starzeniu się po 40. roku życia."
>
  <Navbar currentPath="/blog" fixed={true} />
  <main class="blog-listing">
    <header class="blog-listing__header">
      <h1 class="blog-listing__heading">Blog</h1>
      <p class="blog-listing__sub">Wiedza, inspiracje i świadome podejście do dojrzałości.</p>
    </header>

    <section class="blog-listing__section">
      {posts && posts.length > 0 ? (
        <ul class="blog-listing__grid">
          {posts.map((post: any) => (
            <li class="blog__card">
              {post.thumbnailUrl && (
                <a
                  href={`/blog/${post.slug?.current}`}
                  class="blog__image-link"
                  aria-label={`Czytaj więcej: ${post.title}`}
                >
                  <Image
                    src={post.thumbnailUrl}
                    alt={post.thumbnailAlt || ""}
                    class="blog__image"
                    inferSize={true}
                  />
                </a>
              )}

              <div class="blog__content-wrapper">
                <h2 class="blog__title">
                  <a href={`/blog/${post.slug?.current}`}>{post.title}</a>
                </h2>

                <hr class="blog__divider" />

                <p class="blog__teaser">{post.teaser}</p>

                <a href={`/blog/${post.slug?.current}`} class="blog__btn">CZYTAJ</a>
              </div>
            </li>
          ))}
        </ul>
      ) : (
        <p class="blog-listing__empty">Brak artykułów. Wróć wkrótce!</p>
      )}
    </section>
  </main>
  <Footer />
</Layout>

<style>
  /* --- Wrapper --- */
  .blog-listing {
    padding-top: 0;
    background-color: var(--color-white);
    color: var(--color-dark-green);
  }

  .blog-listing__header {
    max-width: var(--max-width, 1545px);
    margin: 0 auto;
    padding: 120px 24px 48px; /* Kompensuje navbar bez padding-top na main */
    text-align: center;
  }

  .blog-listing__heading {
    font-size: var(--text-extra-large, 3rem);
    font-weight: 700;
    color: var(--color-dark-green);
    margin-bottom: 12px;
  }

  .blog-listing__sub {
    font-size: 1.125rem;
    color: var(--color-dark-green);
    opacity: 0.8;
  }

  .blog-listing__section {
    max-width: var(--max-width, 1545px);
    margin: 0 auto;
    padding: 0 24px 80px;
  }

  /* --- Grid (reuses BlogSection card styles) --- */
  .blog-listing__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 64px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .blog__card {
    display: flex;
    flex-direction: column;
  }

  .blog__image-link {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    margin-bottom: 24px;
    border-radius: 32px;
    overflow: hidden;
  }

  .blog__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .blog__image-link:hover .blog__image {
    transform: scale(1.05);
  }

  .blog__content-wrapper {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .blog__title {
    font-size: 1.45rem;
    font-weight: 700;
    text-transform: uppercase;
    text-align: center;
    margin-bottom: 16px;
    line-height: 1.4;
  }

  .blog__title a {
    color: var(--color-dark-green);
    text-decoration: none;
  }

  .blog__title a:hover {
    color: var(--color-light-green);
  }

  .blog__divider {
    border: none;
    height: 1px;
    background-color: var(--color-dark-green);
    opacity: 0.3;
    margin: 0 0 24px 0;
  }

  .blog__teaser {
    font-size: 1.25rem;
    line-height: 1.5;
    text-align: left;
    margin-bottom: 16px;
    flex: 1;
  }

  .blog__btn {
    display: inline-block;
    width: 100%;
    text-align: center;
    background-color: var(--color-white);
    color: var(--color-dark-green);
    border: 1px solid var(--color-dark-green);
    border-radius: 50px;
    padding: 14px 24px;
    font-size: 1.125rem;
    font-weight: 700;
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .blog__btn:hover {
    background-color: var(--color-dark-green);
    color: var(--color-white);
  }

  .blog-listing__empty {
    text-align: center;
    font-size: 1.125rem;
    opacity: 0.7;
    padding: 3rem 0;
  }

  /* --- Mobile --- */
  @media screen and (max-width: 900px) {
    .blog-listing__grid {
      grid-template-columns: 1fr;
      gap: 56px;
    }
  }
</style>
