---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { loadQuery } from "../../sanity/lib/load-query";
import { PortableText } from "astro-portabletext";

export async function getStaticPaths() {
  const { data: posts } = await loadQuery<any[]>({
    query: `*[_type == "post"]`,
  });

  return posts.map(({ slug }: any) => ({
    params: { slug: slug.current },
  }));
}

const { params } = Astro;

const { data: post } = await loadQuery<any>({
  query: `*[_type == "post" && slug.current == $slug][0] {
    title,
    slug,
    publishedAt,
    teaser,
    body,
    "authorName": author->name,
    "categories": categories[]->title
  }`,
  params,
});
---

<Layout
  title={`${post.title} — Blog IANA`}
  description={post.teaser || `Artykuł: ${post.title} — Blog IANA`}
>
  <Navbar currentPath="/blog" fixed={true} />
  <main class="blog-post">
    <article>
      <header class="post-header">
        <h1>{post.title}</h1>
        <div class="post-meta">
          {
            post.publishedAt && (
              <time datetime={post.publishedAt}>
                {new Date(post.publishedAt).toLocaleDateString("pl-PL", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </time>
            )
          }
          {
            post.authorName && (
              <span class="post-author">Autor: {post.authorName}</span>
            )
          }
        </div>
        {
          post.categories && post.categories.length > 0 && (
            <div class="post-categories">
              {post.categories.map((category: string) => (
                <span class="category-tag">{category}</span>
              ))}
            </div>
          )
        }
      </header>

      <div class="post-body">
        {post.body && <PortableText value={post.body} />}
      </div>

      <footer class="post-footer">
        <a href="/blog" class="back-link">← Wróć do listy artykułów</a>
      </footer>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  .blog-post {
    padding-top: 0;
  }

  article {
    max-width: 760px;
    margin: 0 auto;
    padding: 120px 1.5rem 4rem;
  }

  .post-header {
    margin-bottom: 2.5rem;
    border-bottom: 1px solid var(--color-ultra-light-green);
    padding-bottom: 1.5rem;
  }

  .post-header h1 {
    font-size: var(--text-extra-large);
    color: var(--color-dark-green);
    line-height: 1.3;
    margin-bottom: 1rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    font-size: var(--text-small);
    color: var(--color-dark-green);
    opacity: 0.7;
    margin-bottom: 0.75rem;
  }

  .post-author {
    font-weight: 700;
    color: var(--color-light-green);
    opacity: 1;
  }

  .post-categories {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .category-tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: var(--color-background-green);
    color: var(--color-dark-green);
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .post-body {
    color: var(--color-dark-green);
    font-size: 1.0625rem;
    line-height: 1.8;
  }

  .post-body :global(h1),
  .post-body :global(h2),
  .post-body :global(h3),
  .post-body :global(h4) {
    color: var(--color-dark-green);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .post-body :global(h2) {
    font-size: 1.5rem;
  }

  .post-body :global(h3) {
    font-size: 1.25rem;
  }

  .post-body :global(p) {
    margin-bottom: 1.25rem;
  }

  .post-body :global(ul) {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .post-body :global(li) {
    margin-bottom: 0.5rem;
  }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--color-light-green);
    padding-left: 1rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--color-dark-green);
    opacity: 0.85;
  }

  .post-body :global(a) {
    color: var(--color-light-green);
    text-decoration: underline;
  }

  .post-body :global(img) {
    border-radius: 8px;
    margin: 1.5rem 0;
  }

  .post-footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-ultra-light-green);
  }

  .back-link {
    display: inline-block;
    color: var(--color-dark-green);
    font-weight: 700;
    font-size: var(--text-small);
    padding: 0.5rem 1.25rem;
    border: 2px solid var(--color-dark-green);
    border-radius: 24px;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .back-link:hover {
    background-color: var(--color-dark-green);
    color: var(--color-white);
  }
</style>
